{
  "manifest_version": 3,
  "name": "GoMining Data Extractor",
  "version": "1.0",
  "description": "Extrait les données de mining depuis app.gomining.com",
  "permissions": ["storage"],
  "host_permissions": ["https://app.gomining.com/*", "https://api.gomining.com/*"],
  "content_scripts": [
    {
      "matches": ["https://app.gomining.com/*"],
      "js": ["extractor.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:*/*", "file:///*"],
      "js": ["sync-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["https://app.gomining.com/*"]
    }
  ]
}
